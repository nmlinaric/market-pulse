{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/api-gateway/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/api-gateway/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/api-gateway",
  "projects": {
    "alert-service": {
      "type": "application",
      "root": "apps/alert-service",
      "entryFile": "main",
      "sourceRoot": "apps/alert-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/alert-service/tsconfig.app.json"
      }
    },
    "analytics-engine": {
      "type": "application",
      "root": "apps/analytics-engine",
      "entryFile": "main",
      "sourceRoot": "apps/analytics-engine/src",
      "compilerOptions": {
        "tsConfigPath": "apps/analytics-engine/tsconfig.app.json"
      }
    },
    "api-gateway": {
      "type": "application",
      "root": "apps/api-gateway",
      "entryFile": "main",
      "sourceRoot": "apps/api-gateway/src",
      "compilerOptions": {
        "tsConfigPath": "apps/api-gateway/tsconfig.app.json"
      }
    },
    "collector-service": {
      "type": "application",
      "root": "apps/collector-service",
      "entryFile": "main",
      "sourceRoot": "apps/collector-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/collector-service/tsconfig.app.json"
      }
    },
    "common": {
      "type": "library",
      "root": "libs/common",
      "entryFile": "index",
      "sourceRoot": "libs/common/src",
      "compilerOptions": {
        "tsConfigPath": "libs/common/tsconfig.lib.json"
      }
    },
    "database": {
      "type": "library",
      "root": "libs/database",
      "entryFile": "index",
      "sourceRoot": "libs/database/src",
      "compilerOptions": {
        "tsConfigPath": "libs/database/tsconfig.lib.json"
      }
    },
    "identity-service": {
      "type": "application",
      "root": "apps/identity-service",
      "entryFile": "main",
      "sourceRoot": "apps/identity-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/identity-service/tsconfig.app.json"
      }
    },
    "kafka": {
      "type": "library",
      "root": "libs/kafka",
      "entryFile": "index",
      "sourceRoot": "libs/kafka/src",
      "compilerOptions": {
        "tsConfigPath": "libs/kafka/tsconfig.lib.json"
      }
    },
    "stream-processor": {
      "type": "application",
      "root": "apps/stream-processor",
      "entryFile": "main",
      "sourceRoot": "apps/stream-processor/src",
      "compilerOptions": {
        "tsConfigPath": "apps/stream-processor/tsconfig.app.json"
      }
    }
  }
}